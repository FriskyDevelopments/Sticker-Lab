# Environment stage: dev | staging | prod
APP_ENV=dev

# Core infrastructure
DATABASE_URL=postgres://user:password@localhost:5432/stix
REDIS_URL=redis://localhost:6379/0
ASSET_STORAGE_BUCKET=stix-assets-dev

# Optional connectors (examples only)
INSTAGRAM_ACCESS_TOKEN=
X_API_KEY=
DISCORD_WEBHOOK_URL=

# Safety toggles
REQUIRE_MANUAL_APPROVAL=true
ENABLE_PUBLISHING=false
