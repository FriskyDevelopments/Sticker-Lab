# Global
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info
STIX_CORRELATION_HEADER=x-stix-correlation-id

# Persistence / queue
DATABASE_URL=postgres://user:pass@localhost:5432/stix
REDIS_URL=redis://localhost:6379/0
QUEUE_PREFIX=stix-local

# Auth / session
AUTH_ISSUER_URL=https://issuer.example.com
AUTH_AUDIENCE=stix-api
SESSION_SECRET=replace-with-local-secret

# Assets
ASSET_BUCKET=stix-assets-local
ASSET_REGION=us-east-1
ASSET_CDN_BASE_URL=https://cdn.example.com

# Integrations (enable per environment)
DISCORD_BOT_TOKEN=
X_API_KEY=
WEBHOOK_SIGNING_SECRET=replace-with-webhook-secret

# Safety / feature flags
PUBLISH_DRY_RUN=true
ENABLE_PUBLISHING=false
ENABLE_ADAPTER_DISCORD=false
ENABLE_ADAPTER_X=false
ENFORCE_REVIEW_GATE=true
IDEMPOTENCY_TTL_SECONDS=86400
